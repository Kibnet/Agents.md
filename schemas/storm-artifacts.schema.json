{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/storm-artifacts.schema.json",
  "title": "Storm Cloud Product Development Artifacts",
  "type": "object",
  "required": [
    "metadata",
    "vision",
    "product_goal",
    "needs",
    "constraints",
    "stories",
    "tests",
    "code_units",
    "conflicts",
    "dependencies",
    "ranking",
    "process_audit"
  ],
  "properties": {
    "metadata": { "type": "object" },
    "vision": { "type": "object" },
    "product_goal": { "type": "object" },
    "needs": { "type": "array", "items": { "$ref": "#/$defs/need" } },
    "constraints": { "type": "array", "items": { "$ref": "#/$defs/constraint" } },
    "stories": { "type": "array", "items": { "$ref": "#/$defs/story" } },
    "tests": { "type": "array", "items": { "$ref": "#/$defs/test" } },
    "gherkin_features": { "type": "array", "items": { "$ref": "#/$defs/gherkin_feature" } },
    "gherkin_rules": { "type": "array", "items": { "$ref": "#/$defs/gherkin_rule" } },
    "gherkin_scenarios": { "type": "array", "items": { "$ref": "#/$defs/gherkin_scenario" } },
    "step_definitions": { "type": "array", "items": { "$ref": "#/$defs/step_definition" } },
    "code_units": { "type": "array", "items": { "$ref": "#/$defs/code_unit" } },
    "conflicts": { "type": "array", "items": { "$ref": "#/$defs/conflict" } },
    "dependencies": { "type": "array", "items": { "$ref": "#/$defs/dependency" } },
    "ranking": { "type": "array" },
    "process_audit": { "type": "object" }
  },
  "$defs": {
    "evidence": {
      "type": "object",
      "properties": {
        "path": { "type": "string" },
        "symbol": { "type": "string" },
        "line": { "type": ["integer", "string"] },
        "description": { "type": "string" }
      },
      "additionalProperties": true
    },
    "acceptance_criterion": {
      "type": "object",
      "required": ["id", "text", "coverage_level", "linked_tests"],
      "properties": {
        "id": { "type": "string", "pattern": "^AC-[0-9]{4,}$" },
        "text": { "type": "string" },
        "coverage_level": { "enum": ["none", "smoke", "partial", "critical", "full"] },
        "linked_tests": { "type": "array", "items": { "type": "string" } },
        "linked_rules": { "type": "array", "items": { "type": "string" } },
        "linked_scenarios": { "type": "array", "items": { "type": "string" } },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } }
      },
      "additionalProperties": true
    },
    "story": {
      "type": "object",
      "required": ["id", "title", "status", "provenance", "confidence", "acceptance_criteria", "supports_needs", "linked_tests", "linked_code"],
      "properties": {
        "id": { "type": "string", "pattern": "^ST-[0-9]{4,}$" },
        "title": { "type": "string" },
        "status": { "type": "string" },
        "provenance": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "narrative": { "type": "string" },
        "value": { "type": "string" },
        "acceptance_criteria": { "type": "array", "items": { "$ref": "#/$defs/acceptance_criterion" } },
        "supports_needs": { "type": "array", "items": { "type": "string" } },
        "threatens_needs": { "type": "array", "items": { "type": "string" } },
        "linked_tests": { "type": "array", "items": { "type": "string" } },
        "linked_scenarios": { "type": "array", "items": { "type": "string" } },
        "linked_code": { "type": "array", "items": { "type": "string" } },
        "dependencies": { "type": "array", "items": { "type": "string" } },
        "priority": { "type": "object" },
        "behavior_coverage_level": { "type": "integer", "minimum": 0, "maximum": 5 },
        "gherkin_exception": { "type": "string" },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } },
        "assumptions": { "type": "array", "items": { "type": "string" } },
        "open_questions": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "need": {
      "type": "object",
      "required": ["id", "title", "status", "provenance", "confidence"],
      "properties": {
        "id": { "type": "string", "pattern": "^ND-[0-9]{4,}$" },
        "title": { "type": "string" },
        "status": { "type": "string" },
        "provenance": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "description": { "type": "string" },
        "supports_goal": { "type": "string" },
        "supported_by_stories": { "type": "array", "items": { "type": "string" } },
        "protected_by_constraints": { "type": "array", "items": { "type": "string" } },
        "threatened_by_stories": { "type": "array", "items": { "type": "string" } },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } }
      },
      "additionalProperties": true
    },
    "constraint": {
      "type": "object",
      "required": ["id", "title", "status", "provenance", "confidence"],
      "properties": {
        "id": { "type": "string", "pattern": "^CN-[0-9]{4,}$" },
        "title": { "type": "string" },
        "status": { "type": "string" },
        "provenance": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "description": { "type": "string" },
        "protects_needs": { "type": "array", "items": { "type": "string" } },
        "verified_by_tests": { "type": "array", "items": { "type": "string" } },
        "verified_by_scenarios": { "type": "array", "items": { "type": "string" } },
        "enforced_by_code": { "type": "array", "items": { "type": "string" } },
        "threatened_by_stories": { "type": "array", "items": { "type": "string" } },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } }
      },
      "additionalProperties": true
    },
    "test": {
      "type": "object",
      "required": ["id", "name", "path", "linked_stories", "linked_acceptance_criteria", "linked_constraints"],
      "properties": {
        "id": { "type": "string", "pattern": "^TS-[0-9]{4,}$" },
        "name": { "type": "string" },
        "path": { "type": "string" },
        "framework": { "type": "string" },
        "type": { "type": "string" },
        "linked_stories": { "type": "array", "items": { "type": "string" } },
        "linked_acceptance_criteria": { "type": "array", "items": { "type": "string" } },
        "linked_constraints": { "type": "array", "items": { "type": "string" } },
        "linked_scenarios": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string" },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } }
      },
      "additionalProperties": true
    },
    "gherkin_feature": {
      "type": "object",
      "required": ["id", "title", "file"],
      "properties": {
        "id": { "type": "string", "pattern": "^GF-[0-9]{3,}$" },
        "title": { "type": "string" },
        "file": { "type": "string" },
        "supports_needs": { "type": "array", "items": { "type": "string" } },
        "contains_rules": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string" },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } }
      },
      "additionalProperties": true
    },
    "gherkin_rule": {
      "type": "object",
      "required": ["id", "title", "feature_id", "linked_stories", "scenarios"],
      "properties": {
        "id": { "type": "string", "pattern": "^GR-[0-9]{3,}$" },
        "title": { "type": "string" },
        "feature_id": { "type": "string" },
        "linked_stories": { "type": "array", "items": { "type": "string" } },
        "linked_acceptance_criteria": { "type": "array", "items": { "type": "string" } },
        "linked_constraints": { "type": "array", "items": { "type": "string" } },
        "scenarios": { "type": "array", "items": { "type": "string" } },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } }
      },
      "additionalProperties": true
    },
    "gherkin_scenario": {
      "type": "object",
      "required": ["id", "title", "file", "coverage_role", "status"],
      "properties": {
        "id": { "type": "string", "pattern": "^SC-[A-Za-z0-9]+(?:-[A-Za-z0-9]+)*-[0-9]{3,}$" },
        "title": { "type": "string" },
        "file": { "type": "string" },
        "line": { "type": ["integer", "string"] },
        "tags": { "type": "array", "items": { "type": "string" } },
        "linked_story": { "type": "string" },
        "verifies_needs": { "type": "array", "items": { "type": "string" } },
        "protects_constraints": { "type": "array", "items": { "type": "string" } },
        "threatens_needs": { "type": "array", "items": { "type": "string" } },
        "automation_status": { "type": "string" },
        "linked_tests": { "type": "array", "items": { "type": "string" } },
        "step_definitions": { "type": "array", "items": { "type": "string" } },
        "coverage_role": {
          "enum": [
            "happy_path",
            "negative_path",
            "edge_case",
            "business_rule",
            "constraint_check",
            "regression",
            "security",
            "performance",
            "compatibility",
            "accessibility"
          ]
        },
        "status": {
          "enum": [
            "draft",
            "reviewed",
            "automated",
            "manual",
            "failing",
            "passing",
            "deprecated",
            "superseded"
          ]
        },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } }
      },
      "additionalProperties": true
    },
    "step_definition": {
      "type": "object",
      "required": ["id", "path"],
      "properties": {
        "id": { "type": "string", "pattern": "^SD-[0-9]{4,}$" },
        "path": { "type": "string" },
        "symbol": { "type": "string" },
        "framework": { "type": "string" },
        "step_text": { "type": "string" },
        "supports_scenarios": { "type": "array", "items": { "type": "string" } },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } }
      },
      "additionalProperties": true
    },
    "code_unit": {
      "type": "object",
      "required": ["id", "path", "kind", "supports"],
      "properties": {
        "id": { "type": "string", "pattern": "^CU-[0-9]{4,}$" },
        "path": { "type": "string" },
        "symbol": { "type": "string" },
        "kind": { "type": "string" },
        "supports": { "type": "array", "items": { "type": "string" } },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } }
      },
      "additionalProperties": true
    },
    "conflict": {
      "type": "object",
      "required": ["id", "status", "common_objective", "story_or_constraint", "need_a", "need_b", "assumptions", "injections"],
      "properties": {
        "id": { "type": "string", "pattern": "^CF-[0-9]{4,}$" },
        "status": { "type": "string" },
        "common_objective": { "type": "string" },
        "story_or_constraint": { "type": "string" },
        "need_a": { "type": "string" },
        "need_b": { "type": "string" },
        "rule_id": { "type": "string" },
        "scenario_id": { "type": "string" },
        "scenario_data_risk": { "type": "string" },
        "want_a": { "type": "string" },
        "want_b": { "type": "string" },
        "assumptions": { "type": "array", "items": { "type": "string" } },
        "injections": { "type": "array", "items": { "type": "string" } },
        "decision": { "type": "string" },
        "changed_items": { "type": "array", "items": { "type": "string" } },
        "evidence": { "type": "array", "items": { "$ref": "#/$defs/evidence" } }
      },
      "additionalProperties": true
    },
    "dependency": {
      "type": "object",
      "required": ["id", "from", "to", "type", "reason"],
      "properties": {
        "id": { "type": "string", "pattern": "^DP-[0-9]{4,}$" },
        "from": { "type": "string" },
        "to": { "type": "string" },
        "type": { "type": "string" },
        "reason": { "type": "string" }
      },
      "additionalProperties": true
    }
  }
}
